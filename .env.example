# =============================================================================
# Frontend (public — safe to expose to the browser)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# Server-only (used by Next.js Server Components / Route Handlers / middleware)
# =============================================================================
# Service role key — only for trusted server contexts, NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# Supabase Edge Function secrets
# Set these via: supabase secrets set KEY=value
# Do NOT put real values here in production.
# =============================================================================
# OPENAI_API_KEY=sk-...
# MISTRAL_API_KEY=...
# DEEPL_API_KEY=...
# RESEND_API_KEY=re_...
# VPS_API_URL=https://your-ffmpeg-vps.example.com/api
# VPS_API_KEY=...
