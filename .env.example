# Konvertools — environment variables
#
# Copy this file to `.env.local` for local development. On Vercel, set each
# variable in Project Settings → Environment Variables. The `Deno.env`
# values are Edge Function secrets — set them in Supabase Dashboard →
# Project Settings → Edge Functions → Secrets.

# ─── Next.js (browser + server) ────────────────────────────────────────
# Canonical origin of the site (used for absolute URLs, hreflang, OG, etc.).
# In production: https://konvertools.com. On preview deploys, leave unset
# (the code falls back to konvertools.com which is fine for SEO links).
NEXT_PUBLIC_SITE_URL=https://konvertools.com

# Public Supabase credentials — exposed to the browser, scoped by RLS.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # the `anon` JWT, NOT the service_role

# ─── Supabase Edge Function secrets ────────────────────────────────────
# These are NOT loaded by Next.js — set them in the Supabase dashboard.
# Listed here for completeness so you don't forget any when migrating
# projects.

# Auto-provided by Supabase to every Edge Function (do not set manually):
#   SUPABASE_URL
#   SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY

# Billing — Lemon Squeezy (Merchant of Record)
# https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=lsk_live_...
# Generated when creating the webhook in LS dashboard → Settings → Webhooks.
# LIVE and TEST modes need DIFFERENT webhooks → different signing secrets.
LEMONSQUEEZY_WEBHOOK_SECRET=whsec_...
# Comma-separated admin emails allowed to run the one-time lemonsqueezy-setup
# function (store/variant discovery). Setup is DENIED unless your signed-in
# account email is listed here — keep it empty once onboarding is done.
# SETUP_ADMIN_EMAILS=you@example.com

# Transactional email — Resend
# Used by the send-email edge function (welcome / upgrade / etc.).
RESEND_API_KEY=re_...

# AI providers
MISTRAL_API_KEY=...

# Security tools — Google Safe Browsing (URL scanner / phishing).
GOOGLE_SAFE_BROWSING_KEY=...

# Heavy-job worker (FFmpeg, etc.) running on a separate VPS.
VPS_API_URL=https://worker.example.com
VPS_API_KEY=...

# Optional: extra trusted origins for CORS on edge functions, comma-separated.
# Defaults already cover konvertools.com, konver.app, and *.vercel.app.
# KONVER_EXTRA_ORIGINS=https://staging.konvertools.com,https://custom.example.com
